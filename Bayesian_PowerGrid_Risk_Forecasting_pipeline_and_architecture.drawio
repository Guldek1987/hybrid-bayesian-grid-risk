          <mxGeometry height="46" width="360" x="65" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p2_inputs_row_0" parent="p2_1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=16;spacingLeft=12;spacingRight=12;spacingTop=6;spacingBottom=6;" value="&lt;b&gt;Temporal state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;24-hour line-flow, load, generation, lag, and rolling-feature window.&lt;/span&gt;" vertex="1">
          <mxGeometry height="92.5" width="320" x="85" y="208" as="geometry" />
        </mxCell>
        <mxCell id="p2_inputs_row_1" parent="p2_1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=16;spacingLeft=12;spacingRight=12;spacingTop=6;spacingBottom=6;" value="&lt;b&gt;Graph-topology state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Line adjacency, neighboring-line statistics, degree, centrality, and rating features.&lt;/span&gt;" vertex="1">
          <mxGeometry height="92.5" width="320" x="85" y="300.5" as="geometry" />
        </mxCell>
        <mxCell id="p2_inputs_row_2" parent="p2_1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=16;spacingLeft=12;spacingRight=12;spacingTop=6;spacingBottom=6;" value="&lt;b&gt;Operating regime&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;High-load, high-generation, high-ramp, low-margin, and stress indicators.&lt;/span&gt;" vertex="1">
          <mxGeometry height="92.5" width="320" x="85" y="393" as="geometry" />
        </mxCell>
        <mxCell id="p2_inputs_row_3" parent="p2_1" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;html=1;fontFamily=Times New Roman;fontSize=16;spacingLeft=12;spacingRight=12;spacingTop=6;spacingBottom=6;" value="&lt;b&gt;Forecast horizon&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;1h, 6h, and 24h horizon setting with training-only risk thresholds.&lt;/span&gt;" vertex="1">
          <mxGeometry height="92.5" width="320" x="85" y="485.5" as="geometry" />
        </mxCell>
        <mxCell id="p2_temporal" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#EAF4EC;strokeColor=#8CB596;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.05061728395061778;" value="&lt;b&gt;Temporal Encoder&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Compresses recent load,&lt;br&gt;generation, and line-flow dynamics&lt;br&gt;into temporal representation z&lt;sub&gt;T&lt;/sub&gt;.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="270" x="470" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p2_graph" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#EAF4EC;strokeColor=#8CB596;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.05596107055961064;" value="&lt;b&gt;Graph-Topology Encoder&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Combines adjacent-line flows,&lt;br&gt;degree, centrality, and rating features&lt;br&gt;into graph representation z&lt;sub&gt;G&lt;/sub&gt;.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="274" x="470" y="310" as="geometry" />
        </mxCell>
        <mxCell id="p2_regime" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#F8EFE3;strokeColor=#CFA36A;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.05535499398315276;" value="&lt;b&gt;Regime Encoder&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Represents operating stress&lt;br&gt;and high-ramp conditions&lt;br&gt;as regime representation z&lt;sub&gt;R&lt;/sub&gt;.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="277" x="470" y="490" as="geometry" />
        </mxCell>
        <mxCell id="p2_fusion" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#E8F4F3;strokeColor=#7BB8B6;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.04444444444444596;" value="&lt;b&gt;Graph-Temporal Fusion&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Forms joint model state:&lt;br&gt;z = [z&lt;sub&gt;T&lt;/sub&gt;, z&lt;sub&gt;G&lt;/sub&gt;, z&lt;sub&gt;R&lt;/sub&gt;, h].&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="225" x="802" y="310" as="geometry" />
        </mxCell>
        <mxCell id="p2_forecast" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#E8F4F3;strokeColor=#7BB8B6;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.06140350877193083;" value="&lt;b&gt;Point Forecast Backbone&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Validation-selected forecasting core&lt;br&gt;predicts future line flow.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="228" x="1067" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p2_residual" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#F8EFE3;strokeColor=#CFA36A;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.05409356725146166;" value="&lt;b&gt;Residual Correction&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Corrects near-threshold and&lt;br&gt;high-risk forecast errors.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="228" x="1067" y="310" as="geometry" />
        </mxCell>
        <mxCell id="p2_interval" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#F8EFE3;strokeColor=#CFA36A;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.05309734513274638;" value="&lt;b&gt;Conformal Interval Layer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Uses validation residuals to produce&lt;br&gt;lower and upper forecast bounds.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="226" x="1069" y="487" as="geometry" />
        </mxCell>
        <mxCell id="p2_risk" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#F1EDF7;strokeColor=#A693C6;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.06666666666666832;" value="&lt;b&gt;Bayesian Risk Layer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Transforms graph-temporal evidence into&lt;br&gt;posterior overload-risk probability.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="230" x="1335" y="130" as="geometry" />
        </mxCell>
        <mxCell id="p2_calib" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#F1EDF7;strokeColor=#A693C6;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.06666666666666832;" value="&lt;b&gt;Calibration and Decision&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Calibrates probability on validation data&lt;br&gt;and assigns Normal / Warning / Critical.&lt;/span&gt;" vertex="1">
          <mxGeometry height="125" width="230" x="1335" y="313" as="geometry" />
        </mxCell>
        <mxCell id="p2_unc" parent="p2_1" style="shape=process;rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=10;fillColor=#FFF5D9;strokeColor=#C9A84E;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;arcSize=8;shadow=0;size=0.06666666666666832;" value="&lt;b&gt;Uncertainty Layer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:16px&quot;&gt;Combines interval width, posterior entropy,&lt;br&gt;and near-threshold proximity.&lt;/span&gt;" vertex="1">

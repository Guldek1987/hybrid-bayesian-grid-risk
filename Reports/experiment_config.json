    0.99
  ],
  "primary_critical_threshold": "line-specific 95th percentile of training absolute flow",
  "split_protocol": [
    {
      "partition": "train",
      "suffix_groups": "2020 groups 1-3",
      "time_rule": "first 60% within each group",
      "allowed_use": "model fitting, line selection, train thresholds"
    },
    {
      "partition": "validation",
      "suffix_groups": "2020 groups 1-3",
      "time_rule": "next 20% within each group",
      "allowed_use": "hyperparameter selection, calibration, threshold selection"
    },
    {
      "partition": "test",
      "suffix_groups": "2020 groups 1-3",
      "time_rule": "final 20% within each group",
      "allowed_use": "final internal evaluation only"
    },
    {
      "partition": "external_test",
      "suffix_groups": "2020 group 4",
      "time_rule": "all valid target times",
      "allowed_use": "external-like robustness evaluation only"
    }
  ],
  "random_seed": 42,
  "classical_environment": "ai-classic-ml-cpu",
  "deep_learning_environment": "ai-pytorch-mps"

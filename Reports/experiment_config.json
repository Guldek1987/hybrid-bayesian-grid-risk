{
  "title": "Bayesian Temporal Graph Transformer for Probabilistic Overload Risk Forecasting in Power Transmission Grids",
  "dataset_record": "https://zenodo.org/records/13378476",
  "years_used": [
    2020
  ],
  "multi_year_enabled": false,
  "matched_suffix_groups": [
    {
      "year": 2020,
      "suffix": "1"
    },
    {
      "year": 2020,
      "suffix": "2"
    },
    {
      "year": 2020,
      "suffix": "3"
    },
    {
      "year": 2020,
      "suffix": "4"
    }
  ],
  "selected_line_count_default": 100,
  "debug_line_count": 20,
  "forecast_horizons_hours": [
    1,
    6,
    24
  ],
  "risk_thresholds": [
    0.9,
